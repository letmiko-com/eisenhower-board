{
  "name": "eisenhower-board",
  "private": true,
  "version": "1.11.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint src server shared",
    "dev": "vite",
    "dev:server": "npm run build:server && node dist-server/server/index.js",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "build:all": "npm run build && npm run build:server",
    "start": "node dist-server/server/index.js",
    "migrate:auth-reset": "npm run build:server && node dist-server/server/migrateAuthReset.js",
    "preview": "vite preview",
    "test": "vitest",
    "test:server": "vitest run --config vitest.server.config.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "node -e \"try{require.resolve('@vitest/coverage-v8');process.exit(0)}catch{process.exit(1)}\" >/dev/null 2>&1; if [ $? -eq 0 ]; then vitest run --coverage; else vitest run; fi"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/node": "^10.45.0",
    "@sentry/react": "^10.45.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "lucide-react": "^0.469.0",
    "next-themes": "^0.4.4",
    "nodemailer": "^8.0.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "msw": "^2.0.11",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.7",
    "vitest": "^4.1.8"
  }
}
